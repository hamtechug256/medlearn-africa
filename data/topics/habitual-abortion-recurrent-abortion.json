1f\" data-element_type=\"column\" data-e-type=\"column\"> <div class=\"elementor-widget-wrap elementor-element-populated\"> <div class=\"elementor-element elementor-element-21b94ce elementor-widget elementor-widget-text-editor\" data-id=\"21b94ce\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\"> <div class=\"elementor-widget-container\"> <div id=\"ez-toc-container\" class=\"ez-toc-v2_0_81 counter-hierarchy ez-toc-counter ez-toc-grey ez-toc-container-direction\"> <div class=\"ez-toc-title-container\"> <p class=\"ez-toc-title\" style=\"cursor:inherit\">Table of Contents</p> <span class=\"ez-toc-title-toggle\"><a href=\"#\" class=\"ez-toc-pull-right ez-toc-btn ez-toc-btn-xs ez-toc-btn-default ez-toc-toggle\" aria-label=\"Toggle Table of Content\"><span class=\"ez-toc-js-icon-con\"><span class=\"\"><span class=\"eztoc-hide\" style=\"display:none;\">Toggle</span><span class=\"ez-toc-icon-toggle-span\"><svg style=\"fill: #999;color:#999\" xmlns=\"http://www.w3.org/2000/svg\" class=\"list-377408\" width=\"20px\" height=\"20px\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M6 6H4v2h2V6zm14 0H8v2h12V6zM4 11h2v2H4v-2zm16 0H8v2h12v-2zM4 16h2v2H4v-2zm16 0H8v2h12v-2z\" fill=\"currentColor\"></path></svg><svg style=\"fill: #999;color:#999\" class=\"arrow-unsorted-368013\" xmlns=\"http://www.w3.org/2000/svg\" width=\"10px\" height=\"10px\" viewBox=\"0 0 24 24\" version=\"1.2\" baseProfile=\"tiny\"><path d=\"M18.2 9.3l-6.2-6.3-6.2 6.3c-.2.2-.3.4-.3.7s.1.5.3.7c.2.2.4.3.7.3h11c.3 0 .5-.1.7-.3.2-.2.3-.5.3-.7s-.1-.5-.3-.7zM5.8 14.7l6.2 6.3 6.2-6.3c.2-.2.3-.5.3-.7s-.1-.5-.3-.7c-.2-.2-.4-.3-.7-.3h-11c-.3 0-.5.1-.7.3-.2.2-.3.5-.3.7s.1.5.3.7z\"/></svg></span></span></span></a></span></div> <nav><ul class='ez-toc-list ez-toc-list-level-1 ' ><li class='ez-toc-page-1 ez-toc-heading-level-2'><a class=\"ez-toc-link ez-toc-heading-1\" href=\"#HABITUAL_ABORTION_RECURRENT_ABORTION\" >HABITUAL ABORTION (RECURRENT ABORTION)</a></li><li class='ez-toc-page-1 ez-toc-heading-level-2'><a class=\"ez-toc-link ez-toc-heading-2\" href=\"#CRIMINAL_ABORTIONS\" >CRIMINAL ABORTIONS</a></li><li class='ez-toc-page-1 ez-toc-heading-level-2'><a class=\"ez-toc-link ez-toc-heading-3\" href=\"#THERAPEUTIC_ABORTION\" >THERAPEUTIC ABORTION</a></li></ul></nav></div> <h2 style=\"line-height: 1.38; margin-top: 0pt; margin-bottom: 15pt;\"><span class=\"ez-toc-section\" id=\"HABITUAL_ABORTION_RECURRENT_ABORTION\"></span><span style=\"font-size: 16pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ead1dc; font-weight: bold; font-style: normal; font-variant: normal; text-decoration: underline; -webkit-text-decoration-skip: none; text-decoration-skip-ink: none; vertical-align: baseline; white-space: pre-wrap;\">HABITUAL ABORTION (RECURRENT ABORTION)</span><span class=\"ez-toc-section-end\"></span></h2><blockquote style=\"line-height: 1.38; margin-top: 15pt; margin-bottom: 15pt;\"><p><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #fff2cc; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Habitual abortion </span><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">refers to the </span><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #d9ead3; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">occurrence of spontaneous abortion in three or more consecutive pregnancies</span><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">. </span></p></blockquote><ul><li dir=\"ltr\" style=\"line-height: 1.38;\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Recurrent abortion is the consecutive loss of 3 or more fetuses weighing less than 500g.</span></li></ul><p dir=\"ltr\" style=\"line-height: 1.38; margin-top: 15pt; margin-bottom: 15pt;\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">It usually occurs before 20 weeks of gestation and the risk of further abortion increases with further pregnancy loss.</span></p><p dir=\"ltr\" style=\"line-height: 1.38; margin-top: 15pt; margin-bottom: 15pt;\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Approximately 1% of women experience this, with an increased risk of further abortion with each pregnancy loss. The high incidence suggests underlying causes.</span></p> </div> </div> </div> </div> </div> </section> <section class=\"elementor-section elementor-top-section elementor-element elementor-element-df593ac elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-id=\"df593ac\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;_ha_eqh_enable&quot;:false}\"> <div class=\"elementor-container elementor-column-gap-default\"> <div class=\"elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-516a83d\" data-id=\"516a83d\" data-element_type=\"column\" data-e-type=\"column\"> <div class=\"elementor-widget-wrap elementor-element-populated\"> <div class=\"elementor-element elementor-element-8c6890c elementor-widget elementor-widget-html\" data-id=\"8c6890c\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"html.default\"> <div class=\"elementor-widget-container\"> <script async src=\"https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5767364969818632\" crossorigin=\"anonymous\"></script> <ins class=\"adsbygoogle\" style=\"display:block; text-align:center;\" data-ad-layout=\"in-article\" data-ad-format=\"fluid\" data-ad-client=\"ca-pub-5767364969818632\" data-ad-slot=\"6261327459\"></ins>  </div> </div> </div> </div> </div> </section> <section class=\"elementor-section elementor-top-section elementor-element elementor-element-846c489 elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-id=\"846c489\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;_ha_eqh_enable&quot;:false}\"> <div class=\"elementor-container elementor-column-gap-default\"> <div class=\"elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-913313f\" data-id=\"913313f\" data-element_type=\"column\" data-e-type=\"column\"> <div class=\"elementor-widget-wrap elementor-element-populated\"> <div class=\"elementor-element elementor-element-974d1de elementor-widget elementor-widget-image\" data-id=\"974d1de\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"image.default\"> <div class=\"elementor-widget-container\"> <img decoding=\"async\" width=\"1024\" height=\"568\" src=\"/images/Causes-of-Habitual-Abortion-e1705420413595-1024x568.webp\" class=\"attachment-large size-large wp-image-9043\" alt=\"Causes of Habitual Abortion\" srcset=\"/images/Causes-of-Habitual-Abortion-e1705420413595-1024x568.webp 1024w, https://nursesrevisionuganda.com/wp-content/uploads/2024/01/Causes-of-Habitual-Abortion-e1705420413595-600x333.webp 600w, https://nursesrevisionuganda.com/wp-content/uploads/2024/01/Causes-of-Habitual-Abortion-e1705420413595-300x166.webp 300w, https://nursesrevisionuganda.com/wp-content/uploads/2024/01/Causes-of-Habitual-Abortion-e1705420413595-768x426.webp 768w, https://nursesrevisionuganda.com/wp-content/uploads/2024/01/Causes-of-Habitual-Abortion-e1705420413595-1536x852.webp 1536w, https://nursesrevisionuganda.com/wp-content/uploads/2024/01/Causes-of-Habitual-Abortion-e1705420413595.webp 1563w\" sizes=\"(max-width: 1024px) 100vw, 1024px\" /> </div> </div> <div class=\"elementor-element elementor-element-fda4543 elementor-widget elementor-widget-text-editor\" data-id=\"fda4543\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\"> <div class=\"elementor-widget-container\"> <h4 dir=\"ltr\" style=\"line-height: 1.38; margin-top: 15pt; margin-bottom: 15pt;\"><span style=\"font-size: 15pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ead1dc; font-weight: bold; font-style: normal; font-variant: normal; text-decoration: underline; -webkit-text-decoration-skip: none; text-decoration-skip-ink: none; vertical-align: baseline; white-space: pre-wrap;\">Causes of Habitual Abortion</span></h4><ol><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #374151; background-color: #fff2cc; font-weight: 400; font-style: italic; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Genetic causes</span><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">: Abnormal parental karyotype, commonly translocation.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #374151; background-color: #fff2cc; font-weight: 400; font-style: italic; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Immunological factors</span><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">: Women with a history of pregnancy loss lack immunological G (1gG) locking agent (rhesus incompatibility).</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #374151; background-color: #fff2cc; font-weight: 400; font-style: italic; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Endocrine factors:</span><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\"> Hypersecretion of Luteinizing hormone may affect the oocyte or endometrium, leading to errors in implantation.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #374151; background-color: #fff2cc; font-weight: 400; font-style: italic; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Polycystic ovaries</span><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\"> in mothers increase the risk of early pregnancy loss.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #374151; background-color: #fff2cc; font-weight: 400; font-style: italic; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Infections </span><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">(TORCHES): Toxoplasmosis, Rubella, Syphilis, Herpes Simplex Virus, and Cytomegalovirus.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #374151; background-color: #fff2cc; font-weight: 400; font-style: italic; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Structural abnormalities:</span></li></ol><ul><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Uterine abnormalities like bicornuate uterus.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Cervical incompetence.</span></li></ul> </div> </div> </div> </div> </div> </section> <section class=\"elementor-section elementor-top-section elementor-element elementor-element-123ae8a elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-id=\"123ae8a\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;_ha_eqh_enable&quot;:false}\"> <div class=\"elementor-container elementor-column-gap-default\"> <div class=\"elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-3bbf6eb\" data-id=\"3bbf6eb\" data-element_type=\"column\" data-e-type=\"column\"> <div class=\"elementor-widget-wrap elementor-element-populated\"> <div class=\"elementor-element elementor-element-0ec8d6c elementor-widget elementor-widget-html\" data-id=\"0ec8d6c\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"html.default\"> <div class=\"elementor-widget-container\"> <script async src=\"https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5767364969818632\" crossorigin=\"anonymous\"></script>  <ins class=\"adsbygoogle\" style=\"display:block\" data-ad-client=\"ca-pub-5767364969818632\" data-ad-slot=\"7570414357\" data-ad-format=\"auto\" data-full-width-responsive=\"true\"></ins>  </div> </div> </div> </div> </div> </section> <section class=\"elementor-section elementor-top-section elementor-element elementor-element-a50f0bc elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-id=\"a50f0bc\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;_ha_eqh_enable&quot;:false}\"> <div class=\"elementor-container elementor-column-gap-default\"> <div class=\"elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-928f20f\" data-id=\"928f20f\" data-element_type=\"column\" data-e-type=\"column\"> <div class=\"elementor-widget-wrap elementor-element-populated\"> <div class=\"elementor-element elementor-element-d3e856c elementor-widget elementor-widget-text-editor\" data-id=\"d3e856c\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\"> <div class=\"elementor-widget-container\"> <h4 dir=\"ltr\" style=\"line-height: 1.38; margin-top: 15pt; margin-bottom: 15pt;\"><span style=\"font-size: 15pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ead1dc; font-weight: bold; font-style: normal; font-variant: normal; text-decoration: underline; -webkit-text-decoration-skip: none; text-decoration-skip-ink: none; vertical-align: baseline; white-space: pre-wrap;\">Management of Habitual Abortion</span></h4><ol><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Mothers should be referred to specialized clinics for screening services.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">The treatment of recurrent abortion depends on the cause.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Recurrent abortion due to cervical incompetence is treated with cervical suture/ cerclage at the 14th week of pregnancy and remains in place until the 38th week of pregnancy.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\"> Specific treatment for any identified cause, e.g., cervical cerclage at 14 weeks using Shirodkar\u2019s or McDonald&#8217;s method.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">An absorbable suture is inserted at the level of the cervical os, remaining until 38 weeks or the onset of labour when it is removed.</span></li></ol> </div> </div> </div> </div> </div> </section> <section class=\"elementor-section elementor-top-section elementor-element elementor-element-8102578 elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-id=\"8102578\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;_ha_eqh_enable&quot;:false}\"> <div class=\"elementor-container elementor-column-gap-default\"> <div class=\"elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-7b0828d\" data-id=\"7b0828d\" data-element_type=\"column\" data-e-type=\"column\"> <div class=\"elementor-widget-wrap elementor-element-populated\"> <div class=\"elementor-element elementor-element-03c637b elementor-widget elementor-widget-html\" data-id=\"03c637b\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"html.default\"> <div class=\"elementor-widget-container\"> <script async src=\"https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5767364969818632\" crossorigin=\"anonymous\"></script> <ins class=\"adsbygoogle\" style=\"display:block\" data-ad-format=\"fluid\" data-ad-layout-key=\"-6q+ef+1v-2m-h\" data-ad-client=\"ca-pub-5767364969818632\" data-ad-slot=\"2010257102\"></ins>  </div> </div> </div> </div> </div> </section> <section class=\"elementor-section elementor-top-section elementor-element elementor-element-d993cf3 elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-id=\"d993cf3\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;_ha_eqh_enable&quot;:false}\"> <div class=\"elementor-container elementor-column-gap-default\"> <div class=\"elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-ae24b26\" data-id=\"ae24b26\" data-element_type=\"column\" data-e-type=\"column\"> <div class=\"elementor-widget-wrap elementor-element-populated\"> <div class=\"elementor-element elementor-element-8b2fd26 elementor-widget elementor-widget-text-editor\" data-id=\"8b2fd26\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\"> <div class=\"elementor-widget-container\"> <h2 style=\"line-height: 1.38; margin-top: 0pt; margin-bottom: 15pt;\"><span class=\"ez-toc-section\" id=\"CRIMINAL_ABORTIONS\"></span><span style=\"font-size: 16pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ead1dc; font-weight: bold; font-style: normal; font-variant: normal; text-decoration: underline; -webkit-text-decoration-skip: none; text-decoration-skip-ink: none; vertical-align: baseline; white-space: pre-wrap;\">CRIMINAL ABORTIONS</span><span class=\"ez-toc-section-end\"></span></h2><blockquote style=\"line-height: 1.38; margin-top: 15pt; margin-bottom: 15pt;\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #fff2cc; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Criminal abortions</span><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\"> are</span><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #d9ead3; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\"> intentionally performed to end pregnancy, violating the law.</span><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\"> </span></blockquote><p> </p><p dir=\"ltr\" style=\"line-height: 1.38; margin-top: 15pt; margin-bottom: 15pt;\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Implements like knives, sticks, and oxytocin drugs are used, often leading to septic abortion.</span></p> </div> </div> </div> </div> </div> </section> <section class=\"elementor-section elementor-top-section elementor-element elementor-element-b810a1f elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-id=\"b810a1f\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;_ha_eqh_enable&quot;:false}\"> <div class=\"elementor-container elementor-column-gap-default\"> <div class=\"elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-4018e66\" data-id=\"4018e66\" data-element_type=\"column\" data-e-type=\"column\"> <div class=\"elementor-widget-wrap elementor-element-populated\"> <div class=\"elementor-element elementor-element-5d9cb79 elementor-widget elementor-widget-html\" data-id=\"5d9cb79\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"html.default\"> <div class=\"elementor-widget-container\"> <script async src=\"https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5767364969818632\" crossorigin=\"anonymous\"></script> <ins class=\"adsbygoogle\" style=\"display:block\" data-ad-format=\"autorelaxed\" data-ad-client=\"ca-pub-5767364969818632\" data-ad-slot=\"1271890507\"></ins>  </div> </div> </div> </div> </div> </section> <section class=\"elementor-section elementor-top-section elementor-element elementor-element-3c95c3f elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-id=\"3c95c3f\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;_ha_eqh_enable&quot;:false}\"> <div class=\"elementor-container elementor-column-gap-default\"> <div class=\"elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-f96aef3\" data-id=\"f96aef3\" data-element_type=\"column\" data-e-type=\"column\"> <div class=\"elementor-widget-wrap elementor-element-populated\"> <div class=\"elementor-element elementor-element-d075ad9 elementor-widget elementor-widget-text-editor\" data-id=\"d075ad9\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\"> <div class=\"elementor-widget-container\"> <h4 dir=\"ltr\" style=\"line-height: 1.38; margin-top: 0pt; margin-bottom: 18pt;\"><span style=\"font-size: 15pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ead1dc; font-weight: bold; font-style: normal; font-variant: normal; text-decoration: underline; -webkit-text-decoration-skip: none; text-decoration-skip-ink: none; vertical-align: baseline; white-space: pre-wrap;\">Treatment</span></h4><ul><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Treatment follows the protocol for septic abortion.</span></li></ul><p dir=\"ltr\" style=\"line-height: 1.38; margin-top: 15pt; margin-bottom: 15pt;\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #d9ead3; font-weight: bold; font-style: italic; font-variant: normal; text-decoration: underline; -webkit-text-decoration-skip: none; text-decoration-skip-ink: none; vertical-align: baseline; white-space: pre-wrap;\">At the medical Centre.</span></p><ul><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Mother is received and put in bed.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Counselling but she must be sent to the hospital</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">She should be started on Antibiotics for example ceftriaxone 1g stat IV or any other antibiotics available but in large doses.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Resuscitate the mother depending on her condition</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Refer to hospital for further management</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">A full report will be received plus the general examination of the mother.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Re-assurance is necessary</span></li></ul><p dir=\"ltr\" style=\"line-height: 1.38; margin-top: 15pt; margin-bottom: 15pt;\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #d9ead3; font-weight: bold; font-style: italic; font-variant: normal; text-decoration: underline; -webkit-text-decoration-skip: none; text-decoration-skip-ink: none; vertical-align: baseline; white-space: pre-wrap;\">At the Hospital.</span></p><ul><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">The mother is admitted and preferably isolation done due to the fear of infection</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Doctor is informed, Meanwhile the following should be done:</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Histories are obtained from the mother.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">General examination will be done and Vaginal examination too.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">If sepsis has set in, she will be put on IV drugs immediately (antibiotics) like Gentamycin 160 mg o.d for 5/7 and metronidazole 500 mg 8 hourly for 5/7 then the evacuation of the products.</span></li></ul><h4 dir=\"ltr\" style=\"line-height: 1.38; margin-top: 15pt; margin-bottom: 15pt;\"><span style=\"font-size: 15pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ead1dc; font-weight: bold; font-style: normal; font-variant: normal; text-decoration: underline; -webkit-text-decoration-skip: none; text-decoration-skip-ink: none; vertical-align: baseline; white-space: pre-wrap;\">Dangers of Criminal Abortions:</span></h4><ul><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Death due to haemorrhage.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Pelvic Sepsis.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Pelvic peritonitis.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">General peritonitis.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Sterility.</span></li><li dir=\"ltr\" style=\"line-height: 1.38;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Acute renal failure.</span></li></ul> </div> </div> </div> </div> </div> </section> <section class=\"elementor-section elementor-top-section elementor-element elementor-element-8d20313 elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-id=\"8d20313\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;_ha_eqh_enable&quot;:false}\"> <div class=\"elementor-container elementor-column-gap-default\"> <div class=\"elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-389c9ce\" data-id=\"389c9ce\" data-element_type=\"column\" data-e-type=\"column\"> <div class=\"elementor-widget-wrap elementor-element-populated\"> <div class=\"elementor-element elementor-element-35b8f24 elementor-widget elementor-widget-html\" data-id=\"35b8f24\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"html.default\"> <div class=\"elementor-widget-container\"> <script async src=\"https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5767364969818632\" crossorigin=\"anonymous\"></script> <ins class=\"adsbygoogle\" style=\"display:block\" data-ad-format=\"fluid\" data-ad-layout-key=\"-6q+ef+1v-2m-h\" data-ad-client=\"ca-pub-5767364969818632\" data-ad-slot=\"2010257102\"></ins>  </div> </div> </div> </div> </div> </section> <section class=\"elementor-section elementor-top-section elementor-element elementor-element-b862fc5 elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-id=\"b862fc5\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;_ha_eqh_enable&quot;:false}\"> <div class=\"elementor-container elementor-column-gap-default\"> <div class=\"elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-1e9f740\" data-id=\"1e9f740\" data-element_type=\"column\" data-e-type=\"column\"> <div class=\"elementor-widget-wrap elementor-element-populated\"> <div class=\"elementor-element elementor-element-1408b59 elementor-widget elementor-widget-text-editor\" data-id=\"1408b59\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\"> <div class=\"elementor-widget-container\"> <h2 style=\"line-height: 1.38; margin-top: 0pt; margin-bottom: 15pt;\"><span class=\"ez-toc-section\" id=\"THERAPEUTIC_ABORTION\"></span><span style=\"font-size: 16pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ead1dc; font-weight: bold; font-style: normal; font-variant: normal; text-decoration: underline; -webkit-text-decoration-skip: none; text-decoration-skip-ink: none; vertical-align: baseline; white-space: pre-wrap;\">THERAPEUTIC ABORTION</span><span class=\"ez-toc-section-end\"></span></h2><blockquote style=\"line-height: 1.38; margin-top: 15pt; margin-bottom: 15pt;\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #fff2cc; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Therapeutic abortion</span><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\"> consists of </span><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #d9ead3; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">evacuating the uterus and is undertaken as a treatment to save the life of the mother.</span></blockquote><p dir=\"ltr\" style=\"line-height: 1.38; margin-top: 15pt; margin-bottom: 15pt;\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\"> It is performed only by a doctor, with the consent of the woman and her husband.</span></p><p dir=\"ltr\" style=\"line-height: 1.38; margin-top: 15pt; margin-bottom: 15pt;\"><span style=\"font-size: 15pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ead1dc; font-weight: bold; font-style: normal; font-variant: normal; text-decoration: underline; -webkit-text-decoration-skip: none; text-decoration-skip-ink: none; vertical-align: baseline; white-space: pre-wrap;\">Indications for Therapeutic Abortion</span></p><ul style=\"margin-top: 0; margin-bottom: 0; padding-inline-start: 48px;\"><li dir=\"ltr\" style=\"list-style-type: disc; font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: transparent; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre;\" aria-level=\"1\"><p dir=\"ltr\" style=\"line-height: 1.38; margin-top: 15pt; margin-bottom: 0pt;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Chronic nephritis.</span></p></li><li dir=\"ltr\" style=\"list-style-type: disc; font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: transparent; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre;\" aria-level=\"1\"><p dir=\"ltr\" style=\"line-height: 1.38; margin-top: 0pt; margin-bottom: 0pt;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Severe hypertension.</span></p></li><li dir=\"ltr\" style=\"list-style-type: disc; font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: transparent; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre;\" aria-level=\"1\"><p dir=\"ltr\" style=\"line-height: 1.38; margin-top: 0pt; margin-bottom: 0pt;\" role=\"presentation\"><span style=\"font-size: 12pt; font-family: Poppins,sans-serif; color: #000000; background-color: #ffffff; font-weight: 400; font-style: normal; font-variant: normal; text-decoration: none; vertical-align: baseline; white-space: pre-wrap;\">Heart defects.</span></p></li></ul><p> </p> </div> </div> </div> </div> </div> </section> <section class=\"elementor-section elementor-top-section elementor-element elementor-element-49b64bf elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-id=\"49b64bf\" data-element_type=\"section\" data-e-type=\"section\" data-settings=\"{&quot;_ha_eqh_enable&quot;:false}\"> <div class=\"elementor-container elementor-column-gap-default\"> <div class=\"elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-5d855d6\" data-id=\"5d855d6\" data-element_type=\"column\" data-e-type=\"column\"> <div class=\"elementor-widget-wrap elementor-element-populated\"> <div class=\"elementor-element elementor-element-86a2bfc elementor-widget elementor-widget-html\" data-id=\"86a2bfc\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"html.default\"> <div class=\"elementor-widget-container\"> <script async src=\"https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5767364969818632\" crossorigin=\"anonymous\"></script> <ins class=\"adsbygoogle\" style=\"display:block\" data-ad-format=\"fluid\" data-ad-layout-key=\"-6q+ef+1v-2m-h\" data-ad-client=\"ca-pub-5767364969818632\" data-ad-slot=\"2010257102\"></ins>  </div> </div> </div> </div> </div> </section> </div> <!-- .entry-content .clear --> ",
  "semester": "year-3-semester-2"
}